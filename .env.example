# Supabase project URL — found in: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon (public) key — found in: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# VAPID public key for Web Push — generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=<your-vapid-public-key>

# VAPID private key — server-side only, never expose to the browser
# Used by the Supabase Edge Function (notification-dispatcher) and local dispatch script
VAPID_PRIVATE_KEY=<your-vapid-private-key>
